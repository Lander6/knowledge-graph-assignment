@base <https://lander6.github.io/knowledge-graph-assignment/vocab.ttl> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<#Person> a rdfs:Class;
rdfs:subClassOf foaf:Person;
rdfs:label "Person" @en;
rdfs:comment "Human being" @en .

<#Student> a rdfs:Class;
rdfs:label "Student" @en;
rdfs:comment "A person enrolled in an educational institution with the aim of learning, studying or training." @en;
rdfs:subClassOf <#Person> .

<#PhDStudent> a rdfs:Class;
rdfs:label "PhD student" @en;
rdfs:comment "A person enrolled in a Doctor of Philosophy (PhD) program who is undertaking advanced study and original research." @en;
rdfs:subClassOf <#Student> .

<#BasketballCoach> a rdfs:Class;
rdfs:label "Basketball coach"@en;
rdfs:comment "A basketball coach is a person who trains and leads basketball players or teams, and is responsible for strategy, player development, and game preparation." @en;
rdfs:subClassOf <#Person> .

<#City> a rdfs:Class;
rdfs:label "City" @en;
rdfs:comment "A city is a larger inhabited urban place." @en.

<#Place> a rdfs:Class;
rdfs:label "Place" @en;
rdfs:comment "A geopgraphical or physical location." @en .

<#Photograph> a rdfs:Class;
rdfs:label "Photograph" @en;
rdfs:comment "A visual image taken with a camera or similar device" @en;
rdfs:subClassOf foaf:Image.

<#age> a rdf:Property;
rdfs:label "age"@en, "leeftijd"@nl;
rdfs:comment "The age of the person." @en;
rdfs:domain <#Person>;
rdfs:range rdfs:Literal .

<#studentNumber> a rdf:Property;
rdfs:label "Student number" @en; 
rdfs:comment "Unique number used to identify a student within the university." @en;
rdfs:domain <#Student>;
rdfs:range rdfs:Literal .

<#from> a rdf:Property; 
rdfs:label "from" @en;
rdfs:comment "Where a person or other object originates from." @en;
rdfs:domain rdfs:Resource;
rdfs:range <#City> .

<#knows> a rdf:Property;
rdfs:label "knows" @en;
rdfs:comment "Relates a person to another person they know." @en; 
rdfs:domain <#Person>;
rdfs:range <#Person>;
rdfs:subPropertyOf foaf:knows .

<#name> a rdf:Property;
rdfs:label "name" @en;
rdfs:comment "What someone or something is called." @en;
rdfs:domain rdfs:Resource;
rdfs:range rdfs:Literal;
rdfs:subPropertyOf foaf:name .

<#photographTitle> a rdf:Property;
rdfs:label "title" @en;
rdfs:comment "The title or name of a photograph." @en;
rdfs:domain <#Photograph>;
rdfs:range rdfs:Literal;
rdfs:subPropertyOf foaf:name.

<#photographer> a rdf:Property;
rdfs:label "photographer" @en;
rdfs:comment "The person that took the picture." @en;
rdfs:domain <#Photograph>;
rdfs:range <#Person>;
rdfs:subPropertyOf foaf:maker.

<#depicts> a rdf:Property;
rdfs:subPropertyOf foaf:depicts;
rdfs:label "depicts" @en;
rdfs:comment "People, objects or places that are shown in the photograph" @en;
rdfs:domain <#Photograph>;
rdfs:range rdfs:Resource.

<#takenAt> a rdf:Property;
rdfs:label "taken in" @en;
rdfs:comment "Location where the photograph was taken" @en;
rdfs:domain <#Photograph>;
rdfs:range rdfs:Resource.

<#photographDescription> a rdf:Property;
rdfs:label "description" @en;
rdfs:comment "describes what is depicted on a photograph" @en;
rdfs:domain <#Photograph>;
rdfs:range rdfs:Literal.




